@article{ross2023,
  title = {Passive Acoustic Monitoring Provides a Fresh Perspective on Fundamental Ecological Questions},
  author = {Ross, Samuel R. P.-J. and O'Connell, Darren P. and Deichmann, Jessica L. and Desjonqu{\`e}res, Camille and Gasc, Amandine and Phillips, Jennifer N. and Sethi, Sarab S. and Wood, Connor M. and Burivalova, Zuzana},
  year = 2023,
  journal = {Functional Ecology},
  volume = {37},
